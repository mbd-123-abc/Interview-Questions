# Application
PORT=3000
NODE_ENV=development

# Database (Prisma)
# For production use a real DB URL, e.g. postgresql://user:pass@host:5432/db
DATABASE_URL="file:./dev.db"

# CORS — comma-separated origins allowed to call the API
CORS_ORIGIN=http://localhost:5173

# HCM integration
HCM_BASE_URL=http://localhost:4000
HCM_TIMEOUT_MS=5000

# HCM webhook shared secret — set this to a strong random value in production
# The webhook controller should verify the X-HCM-Signature header against this
HCM_WEBHOOK_SECRET=change-me-in-production
